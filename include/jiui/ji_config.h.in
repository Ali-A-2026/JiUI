 * @file ji_config.h.in
 * @brief Build-time configuration generated by CMake.
 */

#ifndef JIUI_CONFIG_H
#define JIUI_CONFIG_H

/* --------------------------------------------------------------------------
 * Version
 * -------------------------------------------------------------------------- */
#define JIUI_VERSION_MAJOR  @PROJECT_VERSION_MAJOR@
#define JIUI_VERSION_MINOR  @PROJECT_VERSION_MINOR@
#define JIUI_VERSION_PATCH  @PROJECT_VERSION_PATCH@
#define JIUI_VERSION_STRING "@PROJECT_VERSION@"

/* --------------------------------------------------------------------------
 * Linkage model (exactly one is defined)
 * -------------------------------------------------------------------------- */
#ifndef JIUI_SHARED
#cmakedefine JIUI_SHARED
#endif
#ifndef JIUI_STATIC
#cmakedefine JIUI_STATIC
#endif

/* --------------------------------------------------------------------------
 * Rendering backends
 * -------------------------------------------------------------------------- */
#ifndef JIUI_ENABLE_OPENGL
#cmakedefine JIUI_ENABLE_OPENGL
#endif
#ifndef JIUI_ENABLE_VULKAN
#cmakedefine JIUI_ENABLE_VULKAN
#endif

/* --------------------------------------------------------------------------
 * Platform backends
 * -------------------------------------------------------------------------- */
#ifndef JIUI_ENABLE_X11
#cmakedefine JIUI_ENABLE_X11
#endif
#ifndef JIUI_ENABLE_WAYLAND
#cmakedefine JIUI_ENABLE_WAYLAND
#endif

/* --------------------------------------------------------------------------
 * Build options
 * -------------------------------------------------------------------------- */
#cmakedefine JIUI_BUILD_EXAMPLES
#cmakedefine JIUI_BUILD_TESTS
#cmakedefine JIUI_BUILD_JIGEN

/* --------------------------------------------------------------------------
 * ABI version (frozen for v1.x)
 * -------------------------------------------------------------------------- */
#define JIUI_ABI_VERSION_MAJOR 1
#define JIUI_ABI_VERSION_MINOR 0
#define JIUI_ABI_VERSION_PATCH 0
#define JIUI_ABI_VERSION_STRING "1.0.0"

#endif /* JIUI_CONFIG_H */
